# ─── VERDANDI LOOM — Environment Variables ─────────────────────────────────
# Copy to .env and adjust values for your environment.
# Variables marked [REQUIRED in prod] MUST be set when NODE_ENV=production.

# ─── General ───────────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info

# ─── Chur (BFF / Auth Gateway) ────────────────────────────────────────────
PORT=3000
CORS_ORIGIN=http://localhost:5173

# Keycloak OIDC
KEYCLOAK_URL=http://localhost:8180
KEYCLOAK_REALM=seer
KEYCLOAK_CLIENT_ID=verdandi-bff
KEYCLOAK_CLIENT_SECRET=verdandi-bff-secret-dev    # [REQUIRED in prod]
COOKIE_SECRET=dev-cookie-secret                    # [REQUIRED in prod]

# SHUTTLE / ArcadeDB proxy
LINEAGE_API_URL=http://localhost:8080
ARCADEDB_URL=http://localhost:2480
ARCADEDB_DB=hound
ARCADEDB_USER=root
ARCADEDB_PASS=playwithdata                         # [REQUIRED in prod]

# ─── SHUTTLE (Quarkus) ────────────────────────────────────────────────────
# Configured via SHUTTLE/src/main/resources/application.properties
# Override with env vars using QUARKUS_ prefix:
# QUARKUS_REST_CLIENT_ARCADE_URL=http://arcadedb:2480

# ─── verdandi (Vite frontend) ─────────────────────────────────────────────
# VITE_GRAPHQL_URL=/graphql          # default: relative to origin (via Chur proxy)
# VITE_AUTH_URL=/auth                # default: relative to origin (via Chur proxy)

# ─── ArcadeDB ─────────────────────────────────────────────────────────────
ARCADEDB_ADMIN_PASSWORD=playwithdata
