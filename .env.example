# ─── VERDANDI LOOM — Environment Variables ─────────────────────────────────
# Copy to .env and adjust values for your environment.
# Variables marked [REQUIRED in prod] MUST be set when NODE_ENV=production.
#
# ┌──────────────────────────────────────────────────────────────────────────┐
# │  PORT MAP                                                               │
# │                                                                         │
# │  Service      Dev Port    Docker Port   Internal Port                   │
# │  ───────────  ──────────  ───────────   ─────────────                   │
# │  verdandi      :5173       :15173        :5173 (nginx)                  │
# │  Chur (BFF)    :3000       :13000        :3000                          │
# │  SHUTTLE        :8080       :18080        :8080                          │
# │  Keycloak      :8180       :18180        :8180                          │
# │  ArcadeDB      :2480       :2480         :2480 (external container)     │
# │                                                                         │
# │  Docker ports = dev ports + 10000 (except ArcadeDB, always :2480)       │
# │                                                                         │
# │  DEV MODES                                                              │
# │  ──────────                                                             │
# │  Pure dev:    gradlew devAll → SHUTTLE(:8080) + Chur(:3000) + Vite(:5173) │
# │               Requires local Keycloak on :8180                          │
# │                                                                         │
# │  Hybrid dev:  docker compose up → Keycloak(:18180) + SHUTTLE(:18080)    │
# │               + local Chur(:3000) + Vite(:5173)                         │
# │               Set KEYCLOAK_URL & LINEAGE_API_URL to Docker ports        │
# └──────────────────────────────────────────────────────────────────────────┘

# ─── General ───────────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info

# ─── Chur (BFF / Auth Gateway) ────────────────────────────────────────────
PORT=3000
CORS_ORIGIN=http://localhost:5173

# Keycloak OIDC
# Pure dev:   http://localhost:8180   (local Keycloak)
# Hybrid dev: http://localhost:18180  (Docker Keycloak)
KEYCLOAK_URL=http://localhost:8180
KEYCLOAK_REALM=seer
KEYCLOAK_CLIENT_ID=verdandi-bff
KEYCLOAK_CLIENT_SECRET=verdandi-bff-secret-dev    # [REQUIRED in prod]
COOKIE_SECRET=dev-cookie-secret                    # [REQUIRED in prod]

# SHUTTLE / ArcadeDB proxy
# Pure dev:   http://localhost:8080   (local SHUTTLE via gradlew quarkusDev)
# Hybrid dev: http://localhost:18080  (Docker SHUTTLE)
LINEAGE_API_URL=http://localhost:8080
ARCADEDB_URL=http://localhost:2480
ARCADEDB_DB=hound
ARCADEDB_USER=root
ARCADEDB_PASS=playwithdata                         # [REQUIRED in prod]

# ─── SHUTTLE (Quarkus) ────────────────────────────────────────────────────
# Configured via SHUTTLE/src/main/resources/application.properties
# Override with env vars using QUARKUS_ prefix:
# QUARKUS_REST_CLIENT_ARCADE_URL=http://arcadedb:2480

# ─── verdandi (Vite frontend) ─────────────────────────────────────────────
# VITE_GRAPHQL_URL=/graphql          # default: relative to origin (via Chur proxy)
# VITE_AUTH_URL=/auth                # default: relative to origin (via Chur proxy)

# ─── ArcadeDB ─────────────────────────────────────────────────────────────
ARCADEDB_ADMIN_PASSWORD=playwithdata
